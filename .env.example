# ---- Runtime ----
APP_ENV=local
LOG_LEVEL=INFO
AWS_REGION=us-east-1

# ---- Auth (Cognito + API Gateway authorizer) ----
COGNITO_USER_POOL_ID=
COGNITO_APP_CLIENT_ID=
JWT_ISSUER=
JWT_AUDIENCE=
JWKS_URL=

# ---- LLM (Anthropic) ----
ANTHROPIC_API_KEY_SECRET_ARN=
ANTHROPIC_MODEL=claude-opus-4-7
ANTHROPIC_MAX_TOKENS=1024
ANTHROPIC_TEMPERATURE=0.2

# ---- Embeddings ----
EMBEDDING_MODEL=voyage-3
EMBEDDING_DIM=1024

# ---- Vector store ----
VECTOR_STORE_PROVIDER=opensearch
VECTOR_STORE_ENDPOINT=
VECTOR_INDEX_NAME=rag-chunks

# ---- DynamoDB ----
DDB_DOCUMENTS_TABLE=rag-documents
DDB_CONVERSATIONS_TABLE=rag-conversations

# ---- Semantic cache (ElastiCache Redis) ----
SEMANTIC_CACHE_ENABLED=true
SEMANTIC_CACHE_REDIS_URL=
SEMANTIC_CACHE_SIMILARITY_THRESHOLD=0.95
SEMANTIC_CACHE_TTL_SECONDS=86400

# ---- Ingestion ----
S3_INGESTION_BUCKET=
S3_PRESIGNED_URL_TTL_SECONDS=900
S3_MAX_UPLOAD_BYTES=104857600
ALLOWED_MIME_TYPES=application/pdf,text/plain,text/markdown,text/html,application/vnd.openxmlformats-officedocument.wordprocessingml.document
INGESTION_WEBHOOK_URL=
INGESTION_WEBHOOK_SECRET_ARN=

# ---- Rate limiting ----
RATE_LIMIT_PER_MINUTE=60

# ---- Guardrails ----
GUARDRAILS_PROVIDER=bedrock-guardrails
GUARDRAILS_POLICY_ID=

# ---- Observability ----
OTEL_EXPORTER_OTLP_ENDPOINT=
ENABLE_XRAY=true
